# Normalise line endings to LF in the repo; checkout as-is on Windows
* text=auto eol=lf
*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.po text eol=lf
*.pot text eol=lf

# Binaries — never mangle
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.mo binary
*.zip binary
